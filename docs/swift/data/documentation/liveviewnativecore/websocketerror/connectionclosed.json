{"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ConnectionClosed"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is returned as soon as the close handshake is finished (we have both sent and"},{"text":" ","type":"text"},{"type":"text","text":"received a close frame) on the server end and as soon as the server has closed the"},{"text":" ","type":"text"},{"text":"underlying connection if this endpoint is a client.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Thus when you receive this, it is safe to drop the underlying connection.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Receiving this error means that the WebSocket object is not usable anymore and the"},{"text":" ","type":"text"},{"text":"only meaningful action with it is dropping it.","type":"text"}]}]}],"sections":[],"metadata":{"roleHeading":"Case","role":"symbol","title":"WebSocketError.ConnectionClosed","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ConnectionClosed"}],"externalID":"s:18LiveViewNativeCore14WebSocketErrorO16ConnectionClosedyA2CmF","modules":[{"name":"LiveViewNativeCore"}],"symbolKind":"case"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"WebSocket connection closed normally. This informs you of the close."},{"text":" ","type":"text"},{"type":"text","text":"It’s not an error as such and nothing wrong happened."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/liveviewnativecore\/websocketerror\/connectionclosed"]}],"hierarchy":{"paths":[["doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore","doc:\/\/liveview-