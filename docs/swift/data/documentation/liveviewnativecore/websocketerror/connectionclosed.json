{"abstract":[{"type":"text","text":"WebSocket connection closed normally. This informs you of the close."},{"text":" ","type":"text"},{"text":"It’s not an error as such and nothing wrong happened.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"ConnectionClosed","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is returned as soon as the close handshake is finished (we have both sent and"},{"text":" ","type":"text"},{"text":"received a close frame) on the server end and as soon as the server has closed the","type":"text"},{"type":"text","text":" "},{"text":"underlying connection if this endpoint is a client.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus when you receive this, it is safe to drop the underlying connection."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Receiving this error means that the WebSocket object is not usable anymore and the"},{"text":" ","type":"text"},{"type":"text","text":"only meaningful action with it is dropping it."}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"title":"WebSocketError.ConnectionClosed","role":"symbol","externalID":"s:18LiveViewNativeCore14WebSocketErrorO16ConnectionClosedyA2CmF","roleHeading":"Case","modules":[{"name":"LiveViewNativeCore"}],"symbolKind":"case","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"ConnectionClosed","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore","doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError"]]},"identifier":{"url":"doc:\/\/liveview-native-core.Li