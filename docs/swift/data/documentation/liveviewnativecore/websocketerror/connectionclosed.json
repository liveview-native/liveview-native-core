{"abstract":[{"type":"text","text":"WebSocket connection closed normally. This informs you of the close."},{"text":" ","type":"text"},{"type":"text","text":"It’s not an error as such and nothing wrong happened."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError\/ConnectionClosed"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/liveviewnativecore\/websocketerror\/connectionclosed"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"LiveViewNativeCore"}],"roleHeading":"Case","role":"symbol","title":"WebSocketError.ConnectionClosed","externalID":"s:18LiveViewNativeCore14WebSocketErrorO16ConnectionClosedyA2CmF","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"ConnectionClosed","kind":"identifier"}],"symbolKind":"case"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore","doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConnectionClosed"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This is returned as soon as the close handshake is finished (we have both sent and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"received a close frame) on the server end and as soon as the server has closed the"},{"text":" ","type":"text"},{"text":"underlying connection if this endpoint is a client.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus when you receive this, it is safe to drop the underlying connection."}]},{"type":"p