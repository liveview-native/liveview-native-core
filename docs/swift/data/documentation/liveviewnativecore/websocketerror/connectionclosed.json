{"kind":"symbol","abstract":[{"text":"WebSocket connection closed normally. This informs you of the close.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It’s not an error as such and nothing wrong happened."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ConnectionClosed"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is returned as soon as the close handshake is finished (we have both sent and"},{"type":"text","text":" "},{"type":"text","text":"received a close frame) on the server end and as soon as the server has closed the"},{"text":" ","type":"text"},{"type":"text","text":"underlying connection if this endpoint is a client."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus when you receive this, it is safe to drop the underlying connection."}]},{"inlineContent":[{"type":"text","text":"Receiving this error means that the WebSocket object is not usable anymore and the"},{"type":"text","text":" "},{"type":"text","text":"only meaningful action with it is dropping it."}],"type":"paragraph"}]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/liveviewnativecore\/websocketerror\/connectionclosed"]}],"identifier":{"url":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError\/ConnectionClosed","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore","doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError"]]},"metadata":{"title":"WebSocketError.ConnectionClosed","fragments":[{"kind":"keyword",