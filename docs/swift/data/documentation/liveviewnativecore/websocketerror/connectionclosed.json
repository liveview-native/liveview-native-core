{"abstract":[{"type":"text","text":"WebSocket connection closed normally. This informs you of the close."},{"text":" ","type":"text"},{"type":"text","text":"It’s not an error as such and nothing wrong happened."}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"externalID":"s:18LiveViewNativeCore14WebSocketErrorO16ConnectionClosedyA2CmF","title":"WebSocketError.ConnectionClosed","roleHeading":"Case","modules":[{"name":"LiveViewNativeCore"}],"role":"symbol","symbolKind":"case","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ConnectionClosed"}]},"hierarchy":{"paths":[["doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore","doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConnectionClosed"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is returned as soon as the close handshake is finished (we have both sent and"},{"type":"text","text":" "},{"text":"received a close frame) on the server end and as soon as the server has closed the","type":"text"},{"type":"text","text":" "},{"text":"underlying connection if this endpoint is a client.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Thus when you receive this, it is safe to drop the underlying connection."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Receiving this error means that the WebSocket object is not usable anymore and the"},{"type":"text","text":" "},{"text":"only meaningful action with it is dropping it.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"d