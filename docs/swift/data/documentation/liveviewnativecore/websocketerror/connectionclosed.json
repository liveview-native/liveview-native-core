rror"]]},"abstract":[{"type":"text","text":"WebSocket connection closed normally. This informs you of the close."},{"type":"text","text":" "},{"type":"text","text":"It’s not an error as such and nothing wrong happened."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://liveview-native-core.LiveViewNativeCore/documentation/LiveViewNativeCore":{"kind":"symbol","title":"LiveViewNativeCore","abstract":[],"identifier":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore","url":"\/documentation\/liveviewnativecore","type":"topic","role":"collection"},"doc://liveview-native-core.LiveViewNativeCore/documentation/LiveViewNativeCore/WebSocketError":{"role":"symbol","kind":"symbol","url":"\/documentation\/liveviewnativecore\/websocketerror","abstract":[{"type":"text","text":"[tokio_tungstenite::tungstenite::error::Error], but with "},{"type":"codeVoice","code":"uniffi"},{"text":" support","type":"text"}],"title":"WebSocketError","identifier":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WebSocketError","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"WebSocketError"}]},"doc://liveview-native-core.LiveViewNativeCore/documentation/LiveViewNativeCore/WebSocketError/ConnectionClosed":{"kind":"symbol","url":"\/documentation\/liveviewnativecore\/websocketerror\/connectionclosed","role":"symbol","title":"WebSocketError.ConnectionClosed","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"ConnectionClosed","kind":"identifier"}],"type":"topic","abstract":[{"text":"WebSocket connection closed normally. This informs you of the close.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It’s not an error as such and nothing wrong happened."}],"identifier":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveVie