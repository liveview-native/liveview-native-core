{"hierarchy":{"paths":[["doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore","doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/liveviewnativecore\/websocketerror\/connectionclosed"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"ConnectionClosed","kind":"identifier"}]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"This is returned as soon as the close handshake is finished (we have both sent and"},{"type":"text","text":" "},{"type":"text","text":"received a close frame) on the server end and as soon as the server has closed the"},{"type":"text","text":" "},{"type":"text","text":"underlying connection if this endpoint is a client."}],"type":"paragraph"},{"inlineContent":[{"text":"Thus when you receive this, it is safe to drop the underlying connection.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Receiving this error means that the WebSocket object is not usable anymore and the"},{"type":"text","text":" "},{"type":"text","text":"only meaningful action with it is dropping it."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"modules":[{"name":"LiveViewNativeCore"}],"symbolKind":"case","role":"symbol","title":"WebSocketError.ConnectionClosed","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConnectionClosed"}],"externalID":"s:18LiveViewNativeCore14WebSocketErrorO16ConnectionClosedyA2CmF","roleHeading":"Case"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"WebSocket connection closed normally. This informs you of the close."},{"type":"text","text":" "},{"type":"text","text":"It’s not an error as such and nothing wrong happened."}],"sections":[],"identifier":{"url":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError\/ConnectionClosed","interfaceLanguage":"swift"},"references":{"doc://liveview-native-core.LiveViewNativeCore/documentation/LiveViewNativeCore/WebSocketError/ConnectionClosed":{"identifier":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore\/WebSocketError\/ConnectionClosed","url":"\/documentation\/liveviewnativecore\/websocketerror\/connectionclosed","type":"topic","title":"WebSocketError.ConnectionClosed","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ConnectionClosed"}],"kind":"symbol","abstract":[{"type":"text","text":"WebSocket connection closed normally. This informs you of the close."},{"text":" ","type":"text"},{"type":"text","text":"It’s not an error as such and nothing wrong happened."}]},"doc://liveview-native-core.LiveViewNativeCore/documentation/LiveViewNativeCore":{"url":"\/documentation\/liveviewnativecore","identifier":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/LiveViewNativeCore","title":"LiveViewNativeCore","role":"collection","kind":"symbol","type":"topic","abstract":[]},"doc://liveview-native-core.LiveViewNativeCore/documentation/LiveViewNativeCore/WebSocketError":{"kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WebSocketError","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"WebSocketError"}],"role":"symbol","url":"\/documentation\/liveviewnativecore\/websocketerror","title":"WebSocketError","abstract":[{"text":"[tokio_tungstenite::tungstenite::error::Error], but with ","type":"text"},{"code":"uniffi","type":"codeVoice"},{"type":"text","text":" support"}],"identifier":"doc:\/\/liveview-native-core.LiveViewNativeCore\/documentation\/Live